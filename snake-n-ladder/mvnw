#!/bin/sh
BASEDIR=$(dirname "$0")
if [ -z "$BASEDIR" ]; then
  BASEDIR=.
fi
MAVEN_PROJECTBASEDIR=$(cd "$BASEDIR" && pwd -P)
JAVA_EXE="${JAVA_HOME}/bin/java"
if [ ! -x "$JAVA_EXE" ]; then
  JAVA_EXE=java
fi
exec "$JAVA_EXE" -classpath "$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar" "-Dmaven.multiModuleProjectDirectory=$MAVEN_PROJECTBASEDIR" org.apache.maven.wrapper.MavenWrapperMain "$@"